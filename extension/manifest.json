{
  "manifest_version": 3,
  "name": "Chrome MCP Bridge",
  "version": "0.4.1",
  "description": "Local read-mostly Chrome MCP bridge for AI agents.",
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "cookies",
    "debugger",
    "history",
    "offscreen",
    "scripting",
    "storage",
    "tabGroups",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Chrome MCP Bridge"
  }
}
